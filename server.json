{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ejwhite7/brandkit-mcp",
  "description": "Expose a company's design system to AI tools via MCP: colors, typography, logos, tokens.",
  "version": "0.1.0",
  "title": "BrandKit MCP",
  "websiteUrl": "https://github.com/ejwhite7/brandkit-mcp#readme",
  "repository": {
    "url": "https://github.com/ejwhite7/brandkit-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "brandkit-mcp",
      "version": "0.1.0",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "serve",
          "valueHint": "command"
        }
      ]
    }
  ]
}
